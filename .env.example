# Copy to .env and adjust. Never commit .env.

DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/fitness
JWT_SECRET=replace-with-openssl-rand-hex-32
APPLE_CLIENT_ID=com.your.app.bundleid
ENV=development

# OpenAI Responses API (diet/workout agent). Required for POST /diet and POST /workouts.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_AGENT_ID=
# OPENAI_TIMEOUT_SECONDS=120

# Local-only: POST /auth/dev (never set ALLOW_DEV_AUTH in production)
ALLOW_DEV_AUTH=false
# Optional: require header X-Dev-Auth when calling POST /auth/dev
# DEV_AUTH_SECRET=
