# Copy to .env and adjust. Never commit .env.

# Primary DB URL variable. In Railway, map this from your Postgres service.
# Example in Railway app service variables:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/fitness
JWT_SECRET=replace-with-openssl-rand-hex-32
APPLE_CLIENT_ID=com.your.app.bundleid
ENV=development

# OpenAI Responses API (diet/workout agent). Required for POST /diet and POST /workouts.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_AGENT_ID=
# OPENAI_TIMEOUT_SECONDS=120

# Local-only: POST /auth/dev (never set ALLOW_DEV_AUTH in production)
ALLOW_DEV_AUTH=false
# Optional: require header X-Dev-Auth when calling POST /auth/dev
# DEV_AUTH_SECRET=

# HTTP request audit (middleware). Comma-separated path prefixes skipped for DB persistence.
# AUDIT_EXCLUDED_PATH_PREFIXES=/health,/docs,/openapi.json,/redoc
# Max bytes stored per request/response body (truncated beyond this).
# AUDIT_MAX_BODY_BYTES=65536
